#Default enchantment slot cap for all capped items not matched by an override.
# Default: 1
# Range: 0 ~ 1024
defaultCap = 1
#Item or item-tag cap overrides in the form item_id=cap or #tag_id=cap.
capOverrides = ["minecraft:iron_sword=1", "minecraft:iron_pickaxe=1", "minecraft:iron_axe=1", "minecraft:iron_shovel=1", "minecraft:iron_hoe=1", "minecraft:iron_helmet=1", "minecraft:iron_chestplate=1", "minecraft:iron_leggings=1", "minecraft:iron_boots=1", "minecraft:diamond_sword=2", "minecraft:diamond_pickaxe=2", "minecraft:diamond_axe=2", "minecraft:diamond_shovel=2", "minecraft:diamond_hoe=2", "minecraft:diamond_helmet=2", "minecraft:diamond_chestplate=2", "minecraft:diamond_leggings=2", "minecraft:diamond_boots=2", "minecraft:netherite_sword=3", "minecraft:netherite_pickaxe=3", "minecraft:netherite_axe=3", "minecraft:netherite_shovel=3", "minecraft:netherite_hoe=3", "minecraft:netherite_helmet=3", "minecraft:netherite_chestplate=3", "minecraft:netherite_leggings=3", "minecraft:netherite_boots=3", "minecraft:golden_sword=3", "minecraft:golden_pickaxe=3", "minecraft:golden_axe=3", "minecraft:golden_shovel=3", "minecraft:golden_hoe=3", "minecraft:golden_helmet=3", "minecraft:golden_chestplate=3", "minecraft:golden_leggings=3", "minecraft:golden_boots=3"]
#Allowed treasure enchantment loot mappings in the form enchantment_id=loot_table_id. Unmapped treasure enchantments are removed everywhere this mod can intercept.
treasureAllowedLootTables = ["minecraft:mending=minecraft:chests/abandoned_mineshaft"]
#Extra chance per abandoned mineshaft chest to inject one mending book.
# Default: 0.05
# Range: 0.0 ~ 1.0
mineshaftMendingChance = 0.05
#Allow applying runes by right-clicking them onto an item in an inventory.
enableRuneRightClick = false
#Allow applying runes through an anvil with the rune in the second input slot.
enableRuneAnvil = true
#Experience level cost for applying a rune through an anvil.
# Default: 5
# Range: 0 ~ 1024
runeAnvilCost = 5
